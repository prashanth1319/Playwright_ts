    "password": "wrong_password",
    "expected": "error",
    "expectedMessage": "Username and password do not match"
  },
  {
    "scenario": "Problem user login (known UI bug user)",
    "username": "problem_user",
    "password": "secret_sauce",
    "expected": "success"
  },
  {
    "scenario": "Empty credentials show validation error",
    "username": "",
    "password": "",
    "expected": "error",
    "expectedMessage": "Username is required"
  }
